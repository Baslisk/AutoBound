# =============================================================================
# AutoBound Web — Docker-local configuration
# =============================================================================
# Uses postgres:15-alpine (port 54322) + MinIO S3 storage (port 9000).
# Copy to web/.env:
#   cp .env.docker.example web/.env
# =============================================================================

# Django
DJANGO_SECRET_KEY=local-dev-secret-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# PostgreSQL (matches docker-compose.yml "db" service)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres

# MinIO S3-compatible storage (matches "minio" service)
# Leave these blank to use local media/ directory instead of MinIO.
S3_ENDPOINT_URL=http://127.0.0.1:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=autobound-media
