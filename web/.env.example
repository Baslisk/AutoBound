# =============================================================================
# AutoBound Web — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored and will NOT be committed to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Django Core
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Set DATABASE_URL to use PostgreSQL.
# Leave BLANK or remove to fall back to in-memory SQLite (default dev mode).
#
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# Optional: connection max age in seconds (default 600 for PostgreSQL)
# CONN_MAX_AGE=600

# Legacy SQLite file-backed mode (only used when DATABASE_URL is empty):
# DB_PATH=db.sqlite3

# ---------------------------------------------------------------------------
# S3-compatible object storage (e.g. MinIO, AWS S3)
# ---------------------------------------------------------------------------
# Set S3_ENDPOINT_URL to enable remote media storage.
# Leave BLANK or remove to use local filesystem (media/ directory).
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=autobound-media
